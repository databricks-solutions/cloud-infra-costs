{
  "datasets": [
    {
      "name": "dataset1",
      "displayName": "gold_unified_costs",
      "queryLines": [
        "SELECT * FROM billing.gcp.gold_unified_costs"
      ]
    },
    {
      "name": "daily_sku_costs",
      "displayName": "Daily Costs by SKU",
      "queryLines": [
        "SELECT\n",
        "  usage_date,\n",
        "  sku_name AS sku,\n",
        "  'Databricks' AS source,\n",
        "  workspace_id,\n",
        "  dbu_list_cost AS cost\n",
        "FROM\n",
        " silver_databricks_usage\n",
        "UNION ALL\n",
        "SELECT\n",
        "  usage_date,\n",
        "  sku_description AS sku,\n",
        "  'GCP' AS source,\n",
        "  NULL AS workspace_id,\n",
        "  net_cost AS cost\n",
        "FROM\n",
        " silver_gcp_billing"
      ],
      "catalog": "billing",
      "schema": "gcp"
    },
    {
      "name": "chargeback_sku",
      "displayName": "Chargeback by SKU",
      "queryLines": [
        "SELECT\n",
        "  usage_date,\n",
        "  sku_name,\n",
        "  billing_origin_product,\n",
        "  workspace_id,\n",
        "  COALESCE(team_tag, 'untagged') AS team,\n",
        "  COALESCE(cost_center_tag, 'untagged') AS cost_center,\n",
        "  cluster_id,\n",
        "  job_id,\n",
        "  job_name,\n",
        "  run_as_user,\n",
        "  is_serverless,\n",
        "  dbu_quantity,\n",
        "  dbu_list_cost\n",
        "FROM\n",
        "  silver_databricks_usage"
      ],
      "catalog": "billing",
      "schema": "gcp"
    },
    {
      "name": "chargeback",
      "displayName": "Chargeback",
      "queryLines": [
        "WITH job_dbu_daily AS (\n",
        "  SELECT\n",
        "    usage_date,\n",
        "    cluster_id,\n",
        "    job_id,\n",
        "    job_name,\n",
        "    run_as_user,\n",
        "    is_serverless,\n",
        "    COALESCE(team_tag, 'untagged') AS team,\n",
        "    COALESCE(cost_center_tag, 'untagged') AS cost_center,\n",
        "    SUM(dbu_list_cost) AS job_dbu_cost\n",
        "  FROM\n",
        "    silver_databricks_usage\n",
        "  GROUP BY\n",
        "    ALL\n",
        "),\n",
        "cluster_dbu_totals AS (\n",
        "  SELECT\n",
        "    usage_date,\n",
        "    cluster_id,\n",
        "    SUM(job_dbu_cost) AS cluster_total_dbu_cost\n",
        "  FROM\n",
        "    job_dbu_daily\n",
        "  WHERE\n",
        "    cluster_id IS NOT NULL\n",
        "  GROUP BY\n",
        "    ALL\n",
        "),\n",
        "gcp_costs AS (\n",
        "  SELECT\n",
        "    usage_date,\n",
        "    cluster_id,\n",
        "    SUM(gcp_net_cost) AS gcp_net_cost\n",
        "  FROM\n",
        "    cost_management.billing.gold_unified_costs\n",
        "  WHERE\n",
        "    cluster_id IS NOT NULL\n",
        "  GROUP BY\n",
        "    ALL\n",
        ")\n",
        "SELECT\n",
        "  j.usage_date,\n",
        "  j.cluster_id,\n",
        "  j.job_id,\n",
        "  j.job_name,\n",
        "  j.run_as_user,\n",
        "  j.team,\n",
        "  j.cost_center,\n",
        "  j.is_serverless,\n",
        "  j.job_dbu_cost,\n",
        "  CASE\n",
        "    WHEN\n",
        "      j.cluster_id IS NOT NULL\n",
        "      AND ct.cluster_total_dbu_cost > 0\n",
        "    THEN\n",
        "      (j.job_dbu_cost / ct.cluster_total_dbu_cost) * COALESCE(g.gcp_net_cost, 0)\n",
        "    ELSE 0\n",
        "  END AS proportional_gcp_cost,\n",
        "  j.job_dbu_cost\n",
        "    + CASE\n",
        "      WHEN\n",
        "        j.cluster_id IS NOT NULL\n",
        "        AND ct.cluster_total_dbu_cost > 0\n",
        "      THEN\n",
        "        (j.job_dbu_cost / ct.cluster_total_dbu_cost) * COALESCE(g.gcp_net_cost, 0)\n",
        "      ELSE 0\n",
        "    END AS total_chargeback_cost,\n",
        "  CASE\n",
        "    WHEN ct.cluster_total_dbu_cost > 0 THEN j.job_dbu_cost / ct.cluster_total_dbu_cost\n",
        "    ELSE 1\n",
        "  END AS dbu_proportion\n",
        "FROM\n",
        "  job_dbu_daily j\n",
        "    LEFT JOIN cluster_dbu_totals ct\n",
        "      ON j.cluster_id = ct.cluster_id\n",
        "      AND j.usage_date = ct.usage_date\n",
        "    LEFT JOIN gcp_costs g\n",
        "      ON j.cluster_id = g.cluster_id\n",
        "      AND j.usage_date = g.usage_date"
      ],
      "catalog": "billing",
      "schema": "gcp"
    }
  ],
