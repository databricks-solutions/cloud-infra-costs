  {
   "cell_type": "sql",
   "metadata": {},
   "source": [
    "CREATE OR REFRESH STREAMING TABLE ${bronze_table_name}\n",
    "CLUSTER BY AUTO\n",
    "AS SELECT *, _metadata AS source_metadata\n",
    "FROM STREAM read_files('${source_file_path}')"
   ]
  },
  {
   "cell_type": "sql",
   "metadata": {},
   "source": [
    "CREATE OR REFRESH STREAMING TABLE ${silver_table_name}\n",
    "CLUSTER BY AUTO\n",
    "AS SELECT\n",
    "  -- Path-derived metadata\n",
    "  split_part(source_metadata.file_path, '/', ${ingestion_date_depth}) AS ingestion_date,\n",
    "  -- Billing period from data (GCP uses invoice.month, not file path)\n",
    "  invoice.month AS billing_period,\n",
    "  -- Top-level fields\n",
    "  billing_account_id,\n",
    "  cost_type,\n",
    "  cost,\n",
    "  cost_at_list,\n",
    "  currency,\n",
    "  -- Service\n",
    "  service.id AS service_id,\n",
    "  service.description AS service_description,\n",
    "  -- SKU\n",
    "  sku.id AS sku_id,\n",
    "  sku.description AS sku_description,\n",
    "  -- Timestamps\n",
    "  usage_start_time,\n",
    "  usage_end_time,\n",
    "  -- Project\n",
    "  project.id AS project_id,\n",
    "  project.name AS project_name,\n",
    "  -- Location\n",
    "  location.location AS location_location,\n",
    "  location.country AS location_country,\n",
    "  location.region AS location_region,\n",
    "  location.zone AS location_zone,\n",
    "  -- Usage\n",
    "  usage.amount AS usage_amount,\n",
    "  usage.unit AS usage_unit,\n",
    "  usage.amount_in_pricing_units AS usage_amount_in_pricing_units,\n",
    "  usage.pricing_unit AS usage_pricing_unit,\n",
    "  -- Price\n",
    "  price.effective_price AS price_effective_price,\n",
    "  -- Resource (detailed export only)\n",
    "  resource.name AS resource_name,\n",
    "  resource.global_name AS resource_global_name,\n",
    "  -- Credits: aggregate the repeated credits array\n",
    "  AGGREGATE(credits, CAST(0.0 AS DOUBLE), (acc, x) -> acc + x.amount) AS credits_total,\n",
    "  -- Databricks labels extracted from ARRAY<STRUCT<key, value>>\n",
    "  FILTER(labels, x -> x.key = 'vendor')[0].value AS db_vendor,\n",
    "  FILTER(labels, x -> x.key = 'clusterid')[0].value AS db_cluster_id,\n",
    "  FILTER(labels, x -> x.key = 'clustername')[0].value AS db_cluster_name,\n",
    "  FILTER(labels, x -> x.key = 'creator')[0].value AS db_creator,\n",
    "  FILTER(labels, x -> x.key = 'jobid')[0].value AS db_job_id,\n",
    "  FILTER(labels, x -> x.key = 'runname')[0].value AS db_run_name,\n",
    "  FILTER(labels, x -> x.key = 'databricksinstancepoolid')[0].value AS db_instance_pool_id,\n",
    "  -- Retain raw labels for dashboard label exploration\n",
    "  labels,\n",
    "  source_metadata\n",
    "FROM STREAM(${bronze_table_name})"
   ]
  },
  {
   "cell_type": "sql",
   "metadata": {},
   "source": [
    "CREATE OR REPLACE MATERIALIZED VIEW ${gold_table_name}\n",
    "CLUSTER BY AUTO\n",
    "AS SELECT\n",
    "  billing_period,\n",
    "  billing_account_id,\n",
    "  service_id,\n",
    "  service_description,\n",
    "  sku_id,\n",
    "  sku_description,\n",
    "  usage_start_time,\n",
    "  usage_end_time,\n",
    "  project_id,\n",
    "  project_name,\n",
    "  location_location,\n",
    "  location_country,\n",
    "  location_region,\n",
    "  location_zone,\n",
    "  cost_type,\n",
    "  cost,\n",
    "  cost_at_list,\n",
    "  currency,\n",
    "  credits_total,\n",
    "  cost + credits_total AS net_cost,\n",
    "  usage_amount,\n",
    "  usage_unit,\n",
    "  price_effective_price,\n",
    "  resource_name,\n",
    "  resource_global_name,\n",
    "  db_vendor,\n",
    "  db_cluster_id,\n",
    "  db_cluster_name,\n",
    "  db_creator,\n",
    "  db_job_id,\n",
    "  db_run_name,\n",
    "  db_instance_pool_id,\n",
    "  labels\n",
    "FROM (\n",
    "  SELECT *,\n",
    "    RANK() OVER (PARTITION BY billing_period ORDER BY ingestion_date DESC) AS rank\n",
    "  FROM ${silver_table_name}\n",
    ") WHERE rank = 1"
   ]
  }
 ],
