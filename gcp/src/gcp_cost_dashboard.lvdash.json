{
  "datasets": [
    {
      "name": "d1a0b1c2",
      "displayName": "Total Cost",
      "queryLines": [
        "SELECT *\n",
        "FROM billing.gcp.gcp_cost_gold"
      ]
    },
    {
      "name": "d2b1c2d3",
      "displayName": "Compute TCO",
      "queryLines": [
        "SELECT\n",
        "  g.*,\n",
        "  c.cluster_name AS system_cluster_name,\n",
        "  c.cluster_source,\n",
        "  c.driver_node_type_id,\n",
        "  c.node_type_id,\n",
        "  j.name AS system_job_name\n",
        "FROM billing.gcp.gcp_cost_gold g\n",
        "LEFT JOIN system.compute.clusters c\n",
        "  ON g.db_cluster_id = c.cluster_id\n",
        "LEFT JOIN system.lakeflow.jobs j\n",
        "  ON g.db_job_id = CAST(j.job_id AS STRING)"
      ]
    },
    {
      "name": "d3c2d3e4",
      "displayName": "Label Analysis",
      "queryLines": [
        "WITH\n",
        "usage AS (\n",
        "  SELECT\n",
        "    date_trunc('QUARTER', usage_start_time) AS usage_quarter,\n",
        "    date_trunc('MONTH', usage_start_time) AS usage_month,\n",
        "    date_trunc('WEEK', usage_start_time) AS usage_week,\n",
        "    DATE(usage_start_time) AS usage_day,\n",
        "    u.*\n",
        "  FROM billing.gcp.gcp_cost_gold AS u\n",
        "),\n",
        "usage_time_key AS (\n",
        "  SELECT\n",
        "    IDENTIFIER(\n",
        "      CASE\n",
        "        WHEN :param_time_key = 'Quarter' THEN 'usage_quarter'\n",
        "        WHEN :param_time_key = 'Month' THEN 'usage_month'\n",
        "        WHEN :param_time_key = 'Week' THEN 'usage_week'\n",
        "        ELSE 'usage_day'\n",
        "      END\n",
        "    ) AS time_key,\n",
        "    *\n",
        "  FROM usage\n",
        ")\n",
        "SELECT\n",
        "  time_key,\n",
        "  service_description,\n",
        "  project_name,\n",
        "  label_entry.key AS label_key,\n",
        "  label_entry.value AS label_value,\n",
        "  cost,\n",
        "  credits_total,\n",
        "  net_cost\n",
        "FROM usage_time_key\n",
        "LATERAL VIEW OUTER EXPLODE(labels) AS label_entry"
      ],
      "parameters": [
        {
          "displayName": "param_time_key",
          "keyword": "param_time_key",
          "dataType": "STRING",
          "defaultSelection": {
            "values": {
              "dataType": "STRING",
              "values": [{"value": "Week"}]
            }
          }
        }
      ]
    },
    {
      "name": "d4d3e4f5",
      "displayName": "Service SKU Breakdown",
      "queryLines": [
        "SELECT\n",
        "  billing_period,\n",
        "  service_description,\n",
        "  sku_description,\n",
        "  project_name,\n",
        "  location_region,\n",
        "  cost_type,\n",
        "  SUM(cost) AS total_cost,\n",
        "  SUM(credits_total) AS total_credits,\n",
        "  SUM(net_cost) AS total_net_cost\n",
        "FROM billing.gcp.gcp_cost_gold\n",
        "GROUP BY ALL"
      ]
    },
    {
      "name": "d5e4f5a6",
      "displayName": "select_time_key",
      "queryLines": [
        "SELECT EXPLODE(ARRAY(\n",
        "  'Day',\n",
        "  'Week',\n",
        "  'Month',\n",
        "  'Quarter'\n",
        ")) AS time_key"
      ]
    },
    {
      "name": "d6f5a6b7",
      "displayName": "select_label_keys",
      "queryLines": [
        "SELECT DISTINCT label_entry.key AS label_key\n",
        "FROM billing.gcp.gcp_cost_gold\n",
        "LATERAL VIEW OUTER EXPLODE(labels) AS label_entry\n",
        "WHERE label_entry.key IS NOT NULL\n",
        "ORDER BY label_key"
      ]
    }
  ],
